{
  "name": "tpo-reynolds-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "next dev",
    "build": "next build",
    "build:workspaces": "npm run build --workspaces --if-present",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "seed": "npm run seed --workspace=packages/db"
  },
  "dependencies": {
    "@prisma/client": "^6",
    "@tanstack/react-query": "^5",
    "lucide-react": "^0.460",
    "next": "16.1.6",
    "openai": "^4",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "autoprefixer": "^10",
    "prisma": "^6",
    "tailwindcss": "^3",
    "tsx": "^4",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
